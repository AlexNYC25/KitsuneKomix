{
  "name": "kisune-komix-worker",
  "version": "0.0.1",
  "description": "Kitsune Komix background worker",
  "imports": {
    "#database/": "../packages/database/src/",
    "#config/": "./src/config/",
    "#logger/": "./src/infrastructure/loggers/",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@^1.1.5",
    "chokidar": "npm:chokidar@^5.0.0",
    "pino": "npm:pino@^10.3.1",
    "zod": "npm:zod@^4.4.3"
  },
  "tasks": {
    "dev": "deno run --watch --allow-net main.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto"
}
