{
  "name": "kitsume-komix-api",
  "version": "0.0.2",
  "description": "Kitsune Komix REST API service",
  "imports": {
    "#root/": "./",
    "#infrastructure/": "./src/infrastructure/",
    "#db/": "./src/infrastructure/db/",
    "#docs": "./docs",
    "#logger/": "./src/infrastructure/logger/",
    "#app/": "./src/app/",
    "#zod/": "./src/shared/zod/",
    "#types/": "./src/shared/types/",
    "#utilities/": "./src/shared/utilities/",
    "#config/": "./src/config/",
    "#modules/": "./src/modules/",
    "#routes/": "./src/routes/",
    "@hono/swagger-ui": "npm:@hono/swagger-ui@^0.5.3",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^1.4.0",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.7.6",
    "@libsql/client": "npm:@libsql/client@^0.15.15",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/path": "jsr:@std/path@^1.1.5",
    "bcrypt": "npm:bcrypt@^6.0.0",
    "chokidar": "npm:chokidar@^4.0.3",
    "comic-metadata-tool": "npm:comic-metadata-tool@^1.3.3",
    "drizzle-dbml-generator": "npm:drizzle-dbml-generator@^0.10.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "drizzle-orm": "npm:drizzle-orm@0.45.2",
    "drizzle-zod": "npm:drizzle-zod@^0.8.3",
    "hono": "npm:hono@^4.12.23",
    "jose": "npm:jose@^6.2.3",
    "pino": "npm:pino@^9.14.0",
    "pino-pretty": "npm:pino-pretty@^13.1.3",
    "sharp": "npm:sharp@^0.34.5",
    "utility-types": "npm:utility-types@^3.11.0",
    "zod": "npm:zod@^4.4.3"
  },
  "exports": {
    "main": "./main.ts"
  },
  "tasks": {
    "dev": "deno run --allow-run=unzip,7z,7za --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --watch ./main.ts",
    "start": "deno run --allow-run=unzip,7z,7za --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys ./main.ts",
    "worker:dev": "deno run --allow-run=unzip,7z,7za --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --watch ./worker.ts",
    "worker:start": "deno run --allow-run=unzip,7z,7za --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys ./worker.ts",
    "db:generate": "deno run drizzle-kit generate"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto"
}
