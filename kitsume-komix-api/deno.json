{
  "name": "kitsume-komix-api",
  "version": "0.0.2",
  "description": "Kitsune Komix REST API service",
  "imports": {
    "#root/": "./",
    "#infrastructure/": "./src/infrastructure/",
    "#db/": "./src/infrastructure/db/",
    "#logger/": "./src/infrastructure/logger/",
    "#app/": "./src/app/",
    "#zod/": "./src/shared/zod/",
    "#types/": "./src/shared/types/",
    "#interfaces/": "./src/shared/interfaces/",
    "#utilities/": "./src/shared/utilities/",
    "#config/": "./src/config/",
    "#modules/": "./src/modules/",
    "#routes/": "./src/routes/",
    "@hono/swagger-ui": "npm:@hono/swagger-ui@^0.5.2",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^1.1.3",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.7.3",
    "@libsql/client": "npm:@libsql/client@^0.15.15",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.2",
    "bcrypt": "npm:bcrypt@^6.0.0",
    "bullmq": "npm:bullmq@^5.58.9",
    "camelcase-keys": "npm:camelcase-keys@^10.0.0",
    "chokidar": "npm:chokidar@^4.0.3",
    "comic-metadata-tool": "npm:comic-metadata-tool@^1.2.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.5",
    "drizzle-orm": "npm:drizzle-orm@^0.44.6",
    "drizzle-zod": "npm:drizzle-zod@^0.8.3",
    "hono": "npm:hono@^4.9.10",
    "ioredis": "npm:ioredis@^5.10.0",
    "jose": "npm:jose@^6.1.0",
    "pino": "npm:pino@^9.11.0",
    "pino-pretty": "npm:pino-pretty@^13.1.1",
    "redis": "npm:redis@^5.11.0",
    "sharp": "npm:sharp@^0.34.4",
    "zod": "npm:zod@^4.1.11"
  },
  "exports": {
    "main": "./main.ts"
  },
  "tasks": {
    "dev": "deno run --allow-run=unzip,7z,7za --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --watch ./main.ts",
    "start": "deno run --allow-run=unzip,7z,7za --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys ./main.ts",
    "db:generate": "deno run drizzle-kit generate"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto"
}
